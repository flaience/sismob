{
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "module": "CommonJS",
    "target": "ES2021",
    "outDir": "./dist",
    "baseUrl": "../../",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": false,
    "strict": false,
    "paths": {
      "@sismob/database": ["packages/database/index.ts"]
    }
  },
  /* O SEGREDO ESTÁ AQUI: Limitamos o que o compilador enxerga */
  "include": [
    "src/**/*",
    "../../packages/database/index.ts",
    "../../packages/database/schema.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "../../packages/database/drizzle.config.ts", // IGNORA O INTRUSO
    "../../packages/database/drizzle/**/*" // IGNORA AS MIGRAÇÕES
  ]
}

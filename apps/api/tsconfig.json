{
  "compilerOptions": {
    "module": "CommonJS",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "moduleResolution": "node",
    "skipLibCheck": true,
    "paths": {
      "@realstate/database": ["../../packages/database/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "../../packages/database/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}

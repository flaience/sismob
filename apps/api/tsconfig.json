{
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",

    /* O SEGREDO: Removemos o rootDir e deixamos o TS decidir */

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "paths": {
      "@sismob/database": ["../../packages/database/index.ts"]
    }
  },
  /* IMPORTANTE: Aqui incluímos apenas a pasta src */
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test"]
}
